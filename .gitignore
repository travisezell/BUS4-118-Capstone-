# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
test-results/
.nyc_output/
*.lcov

# Next.js
/.next/
/out/

# Production builds
/build
/dist

# Environment files. Keep .env.example committed; everything else is local-only.
.env*
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# Linux
.Trash-*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/

# Local data stores. Chroma persisted volumes, sqlite, parquet caches.
chroma_data/
chroma/
*.parquet
*.sqlite
*.sqlite3
*.db

# Ollama (in case anyone configures OLLAMA_HOME inside the project)
.ollama/

# Cache directories
.cache/
.parcel-cache/
.turbo/

# Misc
*.pem
*.key
*.tgz
.eslintcache
