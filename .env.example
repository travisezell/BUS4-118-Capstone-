# IT Support Assistant. Environment variables.
#
# Copy to .env.local and fill in only what you need. The prototype runs
# fine in mock mode (no API keys needed) for the test suite and the
# basic demo. There are three real paths:
#
#   Path A: mock mode (default, no setup)
#       LLM_PROVIDER=mock
#       VECTOR_STORE=memory
#
#   Path B: real OpenAI + Chroma (the demo path)
#       LLM_PROVIDER=openai + OPENAI_API_KEY
#       VECTOR_STORE=chroma + CHROMA_URL
#
#   Path C: fully local with Ollama (no API keys, no money)
#       LLM_PROVIDER=ollama (Ollama daemon running locally)
#       VECTOR_STORE=chroma (or memory for quick tests)
#
# After changing LLM_PROVIDER, re-run `npm run ingest` because each
# provider uses a different embedding dimension and writes to a
# provider-specific Chroma collection.

# ----------------------------------------------------------------------
# LLM provider
# ----------------------------------------------------------------------
# Supported values:
#   mock    -> deterministic offline provider (default, no API key needed)
#   openai  -> requires OPENAI_API_KEY
#   ollama  -> requires Ollama daemon running locally (free, no key)
#   gemini  -> not implemented yet (falls back to mock)
LLM_PROVIDER=mock

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama
# Setup once on each developer's machine:
#   1. Install Ollama from https://ollama.com/download
#   2. Pull the models:
#        ollama pull llama3.1
#        ollama pull nomic-embed-text
# Then uncomment any of these to override the defaults:
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3.1
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ----------------------------------------------------------------------
# Vector store
# ----------------------------------------------------------------------
# Supported values:
#   memory  -> in-memory store seeded from src/data/knowledge-base.ts (default)
#   chroma  -> talks to a running Chroma server (see docker-compose.yml)
VECTOR_STORE=memory

# Chroma (only used when VECTOR_STORE=chroma)
# CHROMA_URL=http://localhost:8000
# CHROMA_COLLECTION=it-support-kb
