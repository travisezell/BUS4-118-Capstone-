# IT Support Assistant — environment variables
#
# Copy to .env.local and fill in only what you need. The prototype runs
# fine in mock mode (LLM_PROVIDER=mock) without any other vars.

# Pluggable LLM provider. Supported values:
#   mock    -> deterministic offline provider (default)
#   openai  -> requires OPENAI_API_KEY
#   gemini  -> requires GEMINI_API_KEY
#   ollama  -> requires OLLAMA_HOST (e.g. http://localhost:11434)
LLM_PROVIDER=mock

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# Ollama (local)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Vector store
# Default is in-memory. Set CHROMA_URL to enable Chroma.
# CHROMA_URL=http://localhost:8000
