# IT Support Assistant — environment variables
#
# Copy to .env.local and fill in only what you need. The prototype runs
# fine in mock mode (no API keys needed) for the test suite and basic demo.
# Switch to the real RAG path by setting LLM_PROVIDER=openai +
# VECTOR_STORE=chroma below and running `npm run ingest`.

# ─────────────────────────────────────────────────────────────────────
# LLM provider
# ─────────────────────────────────────────────────────────────────────
# Supported values:
#   mock    -> deterministic offline provider (default, no API key needed)
#   openai  -> requires OPENAI_API_KEY
#   gemini  -> not implemented yet (falls back to mock)
#   ollama  -> not implemented yet (falls back to mock)
LLM_PROVIDER=mock

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─────────────────────────────────────────────────────────────────────
# Vector store
# ─────────────────────────────────────────────────────────────────────
# Supported values:
#   memory  -> in-memory store seeded from src/data/knowledge-base.ts (default)
#   chroma  -> talks to a running Chroma server (see docker-compose.yml)
VECTOR_STORE=memory

# Chroma (only used when VECTOR_STORE=chroma)
# CHROMA_URL=http://localhost:8000
# CHROMA_COLLECTION=it-support-kb
